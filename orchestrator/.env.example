# Orchestrator environment. Copy to `orchestrator/.env` (gitignored) and fill in.
#
# NOTHING here is VITE_-prefixed, and nothing here may ever become VITE_: this
# file holds a real secret, and any VITE_ var is bundled into the browser. The
# key stays server-side — that is the whole reason this process exists.

# Required. Your Anthropic API key — https://console.anthropic.com/settings/keys
# Replace the whole placeholder: a real key is ~100+ chars, not "sk-ant-...".
# Leaving this as-is gets a 401 "invalid x-api-key", which reads like a code bug
# but is not one. Use a key dedicated to this app so the Console's per-key cost
# column keeps showing what the dashboard actually spends.
ANTHROPIC_API_KEY=REPLACE_ME

# Optional. Which model /architect draws with. Defaults to claude-sonnet-5 —
# ample for turning a sentence into a handful of blocks, and well under
# claude-opus-4-8 per prompt. claude-haiku-4-5 is the cheap floor; opus is there
# if a diagram genuinely needs better judgement.
ARCHITECT_MODEL=claude-sonnet-5

# Optional. low | medium | high | xhigh | max. Lower = cheaper + faster, at the
# cost of thinking depth. medium suits a graph this small; drop to low if you
# iterate hard on prompts and cost adds up.
ARCHITECT_EFFORT=medium

# Optional. Port to bind on loopback (must match VITE_OS_ORCHESTRATOR_BASE).
ORCHESTRATOR_PORT=8787

# Optional. Comma-separated browser origins allowed to call this server.
# Defaults to the Vite dev server + preview. Do not add a public origin: this
# process holds your API key and can run Claude Code on your filesystem.
ORCHESTRATOR_ALLOWED_ORIGINS=http://localhost:5180,http://localhost:4173
