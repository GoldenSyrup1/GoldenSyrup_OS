# Orchestrator environment. Copy to `orchestrator/.env` (gitignored) and fill in.
#
# NOTHING here is VITE_-prefixed, and nothing here may ever become VITE_: this
# file holds a real secret, and any VITE_ var is bundled into the browser. The
# key stays server-side — that is the whole reason this process exists.

# Required. Your Anthropic API key — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional. Port to bind on loopback (must match VITE_OS_ORCHESTRATOR_BASE).
ORCHESTRATOR_PORT=8787

# Optional. Comma-separated browser origins allowed to call this server.
# Defaults to the Vite dev server + preview. Do not add a public origin: this
# process holds your API key and can run Claude Code on your filesystem.
ORCHESTRATOR_ALLOWED_ORIGINS=http://localhost:5180,http://localhost:4173
