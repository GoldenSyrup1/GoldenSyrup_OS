{
  "name": "goldensyrup-os",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "GoldenSyrup OS — Sriram's personal visual-first command centre",
  "scripts": {
    "dev": "vite",
    "orchestrator": "npm --prefix orchestrator start",
    "orchestrator:install": "npm --prefix orchestrator install",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -b --noEmit"
  },
  "dependencies": {
    "@xyflow/react": "^12.3.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
