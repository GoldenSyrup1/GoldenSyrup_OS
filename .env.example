# GoldenSyrup OS — environment template. Copy to `.env` (gitignored) and fill in.
# All client-exposed vars MUST be prefixed VITE_. Never put secrets that must
# stay private behind VITE_ — anything VITE_ is bundled into the browser build.

# Read-only base URLs of existing Railway backends (safe to expose). Each project
# tile lights up live/blocked from its health endpoint when its base URL is set:
#   WEPort      -> {base}/api/health   ({status,service,version,database})
#   Stall-In    -> {base}/health       ({status,service})  — point at any one service
#   connector   -> {base}/api/health   ({status})
# Each backend must also allow this dashboard's origin in its CORS list, or the
# cross-origin health fetch is blocked and the tile shows "blocked".
VITE_INTEL_API_BASE=https://intel.example.railway.app
VITE_WEPORT_API_BASE=https://api.weportglobal.org
VITE_STALLIN_API_BASE=https://auth-service.example.railway.app
VITE_CONNECTOR_API_BASE=https://connector.example.railway.app

# Optional: a short-lived read token injected at runtime, NOT committed.
# Prefer a backend proxy over shipping any token to the browser.
VITE_CONNECTOR_READ_TOKEN=

# Local orchestrator that executes Claude Code for the Command Console AND generates
# architecture graphs from prompts. Empty ⇒ stub runner/architect (no infra, no cost).
# Endpoints: POST /run (streams run progress), POST /architect ({prompt} → {blocks,links}).
#
# Setting this flips BOTH surfaces off their stubs at once, so start the server
# before you set it: `npm run orchestrator` (see orchestrator/.env.example for its
# ANTHROPIC_API_KEY — that key is server-side and must never be VITE_-prefixed).
# /architect calls the Claude API and costs money per prompt; the stub is free —
# so this stays empty by default. To go live, set it to http://localhost:8787.
# Changing that port also means editing connect-src in index.html.
VITE_OS_ORCHESTRATOR_BASE=

# Cowork bridge file. Claude for Desktop's Cowork is local-only with no API, so it
# writes a JSON snapshot into a connected folder and the OS reads it. Defaults to
# /cowork-state.json (served from public/). Point elsewhere only if Cowork writes
# somewhere the app can fetch. Shape: { generatedAt, tasks: [{id,title,category,status,progress,detail,updated}] }.
VITE_COWORK_STATE_URL=/cowork-state.json
